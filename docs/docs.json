{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Webhook T.",
  "theme": "mint",
  "favicon": "/favicon.ico",
  "colors": {
    "primary": "#ac754e",
    "light": "#ccb49c"
  },
  "logo": "/logo.png",
  "fonts": {
    "body": {
      "family": "Raleway"
    },
    "heading": {
      "family": "Bricolage Grotesque"
    }
  },
  "icons": {
    "library": "tabler"
  },
  "background": {
    "decoration": "grid"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "dark": "github-dark",
        "light": "github-light"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/jiordiviera/hookscope"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/jiordiviera",
      "github": "https://github.com/jiordiviera"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Open App",
          "icon": "link",
          "href": "https://webhooktrap.dev/?utm_source=docs"
        },
        {
          "anchor": "Sponsor",
          "href": "https://webhooktrap.dev/sponsor"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "account-setup"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/inboxes",
              "concepts/capture",
              "concepts/replay",
              "concepts/sharing"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/stripe",
              "integrations/github",
              "integrations/shopify",
              "integrations/other-providers"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/debug-locally",
              "guides/team-debugging",
              "guides/anonymous-vs-saved"
            ]
          },
          {
            "group": "Security & Privacy",
            "pages": ["security/overview", "security/data-storage"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api/overview", "api/authentication"]
          },
          {
            "group": "Endpoints",
            "pages": ["api/inboxes", "api/events", "api/replay"]
          }
        ]
      }
    ]
  }
}

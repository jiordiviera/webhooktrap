# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# Database — Lucid
# @see https://lucid.adonisjs.com/docs/configuration#connection-strings
#--------------------------------------------------------------------
# Dev / prod : Neon ou Postgres managé
DB_CONNECTION=postgres
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/hookscope?sslmode=require

# Tests uniquement (.env.test) : sqlite local
# DB_CONNECTION=sqlite
# DB_DATABASE=tmp/db.sqlite3

#--------------------------------------------------------------------
# CORS
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:3000
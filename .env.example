# =============================================================================
# Hookscope — variables d'environnement (monorepo)
# Copier : cp .env.example .env
# =============================================================================

# --- API (AdonisJS) ---
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}
WEB_URL=http://localhost:3000
SESSION_DRIVER=cookie

# Database (Neon)
# @see https://lucid.adonisjs.com/docs/configuration#connection-strings
DB_CONNECTION=postgres
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/hookscope?sslmode=require

# OAuth — callback: ${APP_URL}/api/v1/auth/oauth/{github|google}/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS
# CORS_ORIGIN=http://localhost:3000

# --- Media (Vercel Blob) ---
# Token: Vercel dashboard → Storage → Blob → Tokens
BLOB_READ_WRITE_TOKEN=
# Public CDN base (custom domain on the Blob store, e.g. https://media.hookscope.dev)
MEDIA_CDN_BASE_URL=https://media.hookscope.dev
MEDIA_MAX_FILE_SIZE_MB=10

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3333


# --- R2 ----

DRIVE_DISK=r2
R2_KEY=
R2_SECRET=
R2_BUCKET=hookscope
R2_ENDPOINT=https://cdn.jiordiviera.me
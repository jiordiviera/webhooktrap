# =============================================================================
# Hookscope — variables d'environnement (monorepo)
# Copier : cp .env.example .env
# =============================================================================

# --- API (AdonisJS) ---
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}
# Public web app URL — ingest links and OAuth return_to (proxied to API for /i/:id)
WEB_URL=http://localhost:7777
SESSION_DRIVER=cookie

# Database (Postgres — local en dev, Neon en prod)
# @see https://lucid.adonisjs.com/docs/configuration#connection-strings
DB_CONNECTION=postgres
DATABASE_URL=postgresql://user:password@localhost:5432/hookscope

# OAuth — callback: ${APP_URL}/api/v1/auth/oauth/{github|google}/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS
# CORS_ORIGIN=http://localhost:7777

# --- Media (Cloudflare R2) ---
DRIVE_DISK=r2
R2_KEY=
R2_SECRET=
R2_BUCKET=hookscope
# S3-compatible API endpoint (not the public CDN URL)
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# Public CDN base for media URLs
MEDIA_CDN_BASE_URL=https://cdn.jiordiviera.me
MEDIA_MAX_FILE_SIZE_MB=10

# --- Mail (Resend) ---
MAIL_MAILER=resend
MAIL_FROM_NAME=Hookscope
MAIL_FROM_ADDRESS=noreply@jiordiviera.me
RESEND_API_KEY=

# --- Web (Next.js) ---
# APP_URL (above) is reused server-side: proxy.ts rewrites /api/v1/* and /hooks/* to the API.
NEXT_PUBLIC_WEB_URL=http://localhost:7777
# =============================================================================
# Webhook Trap — environnement de test (sqlite in-memory, isolé de .env)
# =============================================================================

NODE_ENV=test
TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=silent
APP_KEY=test-app-key-for-japa-runner-only
APP_URL=http://localhost:3333
WEB_URL=http://localhost:7777
SESSION_DRIVER=memory

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

DRIVE_DISK=r2
R2_KEY=test-r2-key
R2_SECRET=test-r2-secret
R2_BUCKET=test-bucket
R2_ENDPOINT=https://test.r2.cloudflarestorage.com
MEDIA_CDN_BASE_URL=https://media.webhooktrap.test

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# =============================================================================
# Webhook Trap — environnement de test (sqlite in-memory, isolé de .env)
# =============================================================================

NODE_ENV=test
TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=silent
APP_KEY=test-app-key-for-japa-runner-only
APP_URL=http://localhost:3333
WEB_URL=http://localhost:7777
SESSION_DRIVER=memory

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

DRIVE_DISK=r2
R2_KEY=test-r2-key
R2_SECRET=test-r2-secret
R2_BUCKET=test-bucket
R2_ENDPOINT=https://test.r2.cloudflarestorage.com
MEDIA_CDN_BASE_URL=https://media.webhooktrap.test
MEDIA_MAX_FILE_SIZE_MB=50

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

LIMITER_STORE=memory

GITHUB_CLIENT_ID=test-github-id
GITHUB_CLIENT_SECRET=test-github-secret
GOOGLE_CLIENT_ID=test-google-id
GOOGLE_CLIENT_SECRET=test-google-secret

NEXT_PUBLIC_APP_URL=${WEB_URL}
NEXT_PUBLIC_API_URL=${APP_URL}

MAIL_MAILER=resend
MAIL_FROM_NAME=Webhook Trap
MAIL_FROM_ADDRESS=noreply@webhooktrap.dev
RESEND_API_KEY=test-resend-key
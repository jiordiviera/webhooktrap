# =============================================================================
# Hookscope — environnement de test (sqlite in-memory, isolé de .env)
# =============================================================================

NODE_ENV=test
TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=silent
APP_KEY=test-app-key-for-japa-runner-only
APP_URL=http://localhost:3333
WEB_URL=http://localhost:3000
SESSION_DRIVER=memory

DB_CONNECTION=sqlite
DB_DATABASE=:memory: